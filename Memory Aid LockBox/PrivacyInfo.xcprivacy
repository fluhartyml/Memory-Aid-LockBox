<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- No tracking (no ATT, no cross-app/cross-site tracking). -->
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<!-- No data is collected by the developer. The vault lives on-device and in
	     the user's own private iCloud (CloudKit); there is no server and no
	     developer access. Matches the published privacy policy. -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<!-- Required-reason API declarations. Only UserDefaults is used (via
	     @AppStorage for user settings/preferences within this app). -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
